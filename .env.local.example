NEXT_PUBLIC_SUPABASE_URL=
# Newer projects: "publishable key". Older: "anon key". Either works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Newer name "secret key", older "service_role key". Same thing.
SUPABASE_SERVICE_ROLE_KEY=

# Optional legacy override for /api/capture — normally Shortcuts use the token
# from Settings → Bearer token (stored as settings.capture_token in Supabase).
CAPTURE_TOKEN=

# Public URL of this app (no trailing slash). Required for Google Calendar OAuth
# and should match Authorized redirect URIs in Google Cloud Console:
#   {NEXT_PUBLIC_SITE_URL}/api/google-calendar/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Canonical production URL for Google OAuth (runtime — overrides stale NEXT_PUBLIC_*).
# Production: https://the-vault-gray-five.vercel.app
VAULT_SITE_URL=

# Google Calendar → Drop (OAuth web client + cron). Create credentials at
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Legacy names (Vercel may still use these — code accepts either pair):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Calendar OAuth CSRF signing (optional if CRON_SECRET is set).
CALENDAR_OAUTH_STATE_SECRET=

# Vercel Cron calls GET /api/cron/calendar-to-drop with Authorization: Bearer …
CRON_SECRET=

# Sheet migration (one-shot) — service-account JSON path. The JSON itself
# is gitignored; download a fresh one from Google Cloud and drop it in
# .secrets/sheet-service-account.json before running `npm run migrate:sheet`.
SHEET_ID=1SNNovuSVLFD2WDawOMV07CyskQPto0MdJR3M0G8Pltw
GOOGLE_APPLICATION_CREDENTIALS=.secrets/sheet-service-account.json
